# Copiați în .env și completați valorile.

DATABASE_URL=sqlite:///./data/app.db
JWT_SECRET=generați-un-secret-lung-aleator
JWT_EXPIRES_MINUTES=1440

# Client ID Web din Google Cloud Console (OAuth 2.0).
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com

# Doar conturi cu acest sufix (conform caietului de sarcini).
STUDENT_EMAIL_SUFFIX=@student.usv.ro

# Origini CORS pentru frontend (virgulă).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Primul administrator (creat doar dacă nu există utilizatorul cu acest email).
BOOTSTRAP_ADMIN_EMAIL=admin@local.test
BOOTSTRAP_ADMIN_PASSWORD=
